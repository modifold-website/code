# Copy this file to .env.docker and change secrets for Docker.

STAGING=false

# Public URLs used by the frontend build and API docs.
PUBLIC_API_BASE=http://127.0.0.1:4000
NEXT_PUBLIC_API_BASE=http://127.0.0.1:4000
API_BASE=http://cronus:4000
FRONTEND_BASE=http://localhost:3000

# Host ports exposed only on 127.0.0.1 for host nginx.
PEGASUS_PORT=3000
CRONUS_PORT=4000
PHPMYADMIN_PORT=8081
# Enable this only when the private ./argus service exists.
# COMPOSE_PROFILES=argus

# MySQL.
MYSQL_ROOT_PASSWORD=change-me-root-password
DB_HOST=mysql
DB_USER=user
DB_PASSWORD=change-me-db-password
DB_NAME=modifold
DB_CONNECTION_LIMIT=50
DB_MAX_IDLE=20
DB_IDLE_TIMEOUT_MS=60000
DB_QUEUE_LIMIT=2000

# ClickHouse.
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=modifold
CLICKHOUSE_USER=modifold
CLICKHOUSE_PASSWORD=change-me-clickhouse-password
CLICKHOUSE_IP_HASH_SECRET=change-me-clickhouse-hash-secret
CLICKHOUSE_MAX_OPEN_CONNECTIONS=10

# Redis.
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379
REDIS_PREFIX=modifold:
REDIS_CONNECT_TIMEOUT_MS=1000
REDIS_MAX_RETRIES_PER_REQUEST=1
REDIS_DEFAULT_TTL_SECONDS=60

# Auth providers.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GITHUB_CLIENT_ID=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
NEXT_PUBLIC_DISCORD_CLIENT_ID=

TELEGRAM_BOT_TOKEN=

# Captcha.
HCAPTCHA_SECRET=
HCAPTCHA_SITE_KEY=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# API security and runtime.
JWT_SECRET=change-me-jwt-secret
TOKEN_CACHE_MAX_SIZE=2000
TOKEN_CACHE_TTL_MS=120000
TOKEN_CACHE_PRUNE_INTERVAL_MS=60000
HTTP_MAX_REQUESTS_PER_SOCKET=250
EXPRESS_BODY_LIMIT=2mb
MEDIA_ROOT=/app/media

# Argus malware/mod review service. Docker runs it as a separate service.
ARGUS_ENABLED=false
ARGUS_BASE_URL=
ARGUS_SHARED_SECRET=
ARGUS_PORT=4010
ARGUS_ALLOWED_FILE_HOSTS=media.modifold.com
ARGUS_TELEGRAM_BOT_TOKEN=
ARGUS_TELEGRAM_CHAT_ID=

# Rate limiting.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_IGNORE_KEY=
RATE_LIMIT_EXPIRY_SECONDS=300
RATE_LIMIT_REQUESTS_PER_MINUTE=300
RATE_LIMIT_BURST_SIZE=120
RATE_LIMIT_PROJECTS_REQUESTS_PER_MINUTE=120
RATE_LIMIT_PROJECTS_BURST_SIZE=40

# Integrations.
CLOUDFLARE_INTEGRATION=false
HYTALE_WIKI_API_TOKEN=
HYTALE_MODDING_API_KEY=
